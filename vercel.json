{
  "functions": {
    "api/ai.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/stripe-webhook.ts": {
      "maxDuration": 30
    },
    "api/generate-questions.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
